# Copy to .env (gitignored) and fill in real values. Never commit secrets.
# Load via pydantic-settings, python-dotenv, or: set -a; . ./.env; set +a

# APP_NAME=my-app
# DEBUG=false
# LOG_LEVEL=INFO

# Secrets — generate real values; never commit a filled-in .env
# SECRET_KEY=change-me

# Database (uncomment if used)
# DATABASE_URL=postgresql://user:pass@localhost:5432/app
