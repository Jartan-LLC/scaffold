# ReadTheDocs config for VERSIONED docs (a page per tag/branch). To use:
#   1. Rename this file to `.readthedocs.yaml`.
#   2. Import the repo at https://readthedocs.org.
# This is the versioned alternative to the single-version GitHub Pages deploy in
# .github/workflows/pages.yml — pick one.
version: 2

build:
  os: ubuntu-24.04
  tools:
    python: "3.12"

python:
  install:
    - method: pip
      path: .
      extra_requirements:
        - docs

sphinx:
  configuration: docs/conf.py
